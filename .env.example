# ADK / Gemini (required for dev — get key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional: for production (Vertex AI)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# Backend app (optional; defaults shown)
AGENT_MODEL=gemini-2.0-flash-live-001
CLICK_AGENT_URL=http://localhost:8001
EXTENSION_WS_PATH=/ws/extension
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
SEND_SAMPLE_RATE=16000
RECEIVE_SAMPLE_RATE=24000
FRAME_RATE=1
FRAME_SIZE=768
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
